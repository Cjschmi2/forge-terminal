{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "forge-terminal",
  "version": "0.1.0",
  "identifier": "com.forge.terminal",
  "build": {
    "beforeDevCommand": "npx vite dev --port 5180 --strictPort",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build",
    "devUrl": "http://localhost:5180"
  },
  "app": {
    "windows": [
      {
        "title": "Forge Terminal",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
